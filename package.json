{
  "name": "pugmill",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "next dev -p ${PORT:-5000} -H 0.0.0.0",
    "build": "next build",
    "start": "node scripts/start.js",
    "lint": "next lint",
    "setup": "tsx scripts/setup.ts",
    "db:push": "drizzle-kit push --force",
    "db:create": "tsx scripts/create-schema.ts",
    "db:init": "npm run db:create && npm run setup",
    "db:migrate": "tsx --env-file=.env.local scripts/run-migrations.ts",
    "db:studio": "drizzle-kit studio",
    "env:check": "tsx scripts/env-check.ts",
    "replit:init": "REPLIT_REINIT=1 tsx scripts/replit-init.ts",
    "postinstall": "node -e \"const fs=require('fs');['server/db.ts','server/db.js','server/schema.ts'].forEach(f=>{if(fs.existsSync(f)){fs.rmSync(f);try{fs.rmdirSync('server')}catch{}console.log('[Pugmill] Removed Replit blueprint file: '+f)}})\"",
    "predev": "fuser -k 5000/tcp 2>/dev/null || true; sleep 1; tsx scripts/replit-init.ts",
    "prestart": "tsx scripts/replit-init.ts",
    "prepare": "husky 2>/dev/null || true"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@aws-sdk/client-s3": "^3.1006.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@types/nodemailer": "^7.0.11",
    "@types/sanitize-html": "^2.16.1",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.468.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^8.0.5",
    "pg": "^8.13.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.1",
    "tailwind-merge": "^2.5.5",
    "tiptap-markdown": "^0.9.0",
    "use-debounce": "^10.1.0",
    "zod": "^3.24.0"
  },
  "overrides": {
    "@auth/core": "0.41.1",
    "esbuild": "^0.25.0",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
